# setup.env.example — Business SecondBrain Template configuration
#
# Copy this file to `setup.env`, fill in values, then run:
#
#   ./setup.sh
#
# setup.sh auto-sources `setup.env` if present in the same directory.
# Variables already exported in your shell take precedence over this file
# only if the file leaves them unset; assignments here will overwrite
# previously-exported values.
#
# Alternative (no file): pass values inline on the command line:
#
#   PROJECT_NAME=My_Vault DOMAIN_NAME=Marketing \
#   PRIMARY_DOMAINS="..." VAULT_ABS_PATH="$(pwd)" \
#   ./setup.sh
#
# Validation rules per variable are listed below in comments. Quoting is
# only required for values containing spaces or non-ASCII characters
# (e.g., Korean text).

# REQUIRED — Project identity.
# Regex: ^[A-Za-z][A-Za-z0-9_]*$  (snake_case or PascalCase ASCII)
# No spaces, no Korean, no special characters.
# Examples: My_Vault, MyVault, project_42
PROJECT_NAME=My_Vault

# REQUIRED — Primary application domain (single PascalCase word).
# Regex: ^[A-Z][A-Za-z]*$   (no underscore, no digits)
# Used in <Domain>_Context.md filename and routing references.
# Examples: Marketing, Engineering, Finance, Research
DOMAIN_NAME=Marketing

# REQUIRED — Comma-separated description of primary application domains.
# 1–200 characters. Forbidden characters: < > &
# Examples (Korean OK):
#   "IT 제품 기획, 의사결정 분석"
#   "marketing campaign design, customer journey analysis"
PRIMARY_DOMAINS="IT 제품 기획, 의사결정 분석"

# OPTIONAL — Recurring tasks the vault supports.
# Leave as empty string ("") or set to "(skip)" to omit.
RECURRING_TASKS="주간 회고, 분기 검토"

# REQUIRED — Absolute path to this vault directory (must exist).
# Default: $(pwd) — the directory you run setup.sh from.
# Override only if you intend to set up a different vault directory.
VAULT_ABS_PATH=$(pwd)
